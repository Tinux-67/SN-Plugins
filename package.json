{
  "name": "sn-plugins",
  "version": "0.2.0",
  "description": "Standard Notes plugins by Tinux-67",
  "main": "dist/index.html",
  "scripts": {
    "dev": "npx serve src/note-graph",
    "dev:note-graph": "npx serve src/note-graph",
    "build": "npm run build:note-graph",
    "build:note-graph": "mkdir -p dist/note-graph && cp -r src/note-graph/* dist/note-graph/ && cd dist/note-graph && sed -i 's|src/note-graph/||g' index.html",
    "build:all": "npm run build:note-graph",
    "start": "npm run dev",
    "start:note-graph": "npm run dev:note-graph",
    "package": "npm run build && cd dist && zip -r ../latest.zip .",
    "package:note-graph": "npm run build:note-graph && cd dist/note-graph && zip -r ../../note-graph.zip ."
  },
  "dependencies": {
    "d3": "^7.8.5",
    "sn-extension-api": "^1.0.0"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "copyfiles": "^2.4.1",
    "typescript": "^5.0.0",
    "serve": "^14.0.0"
  },
  "keywords": [
    "standard-notes",
    "plugin",
    "extension",
    "note-graph",
    "visualization",
    "tags"
  ],
  "author": "Tinux-67",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tinux-67/SN-Plugins.git"
  }
}
